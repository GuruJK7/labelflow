generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- AUTH ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  tenant   Tenant?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- TENANT ---

model Tenant {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  slug      String   @unique
  apiKey    String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Shopify
  shopifyStoreUrl String?
  shopifyToken    String? // Encrypted AES-256

  // DAC
  dacUsername String?
  dacPassword String? // Encrypted AES-256

  // Email
  emailHost String?
  emailPort Int?    @default(587)
  emailUser String?
  emailPass String? // Encrypted AES-256
  emailFrom String?
  storeName String?

  // Config
  paymentThreshold    Float   @default(4000)
  paymentRuleEnabled  Boolean @default(false)
  cronSchedule        String  @default("*/15 * * * *")
  scheduleSlots       Json?   // [{ time: "09:00", maxOrders: 0 }] — 0 means unlimited
  timezone            String  @default("America/Montevideo")
  maxOrdersPerRun     Int     @default(20)
  isActive            Boolean @default(false)

  // Order processing
  orderSortDirection  String  @default("oldest_first")
  allowedProductTypes Json?
  productTypeCache    Json?

  // Stripe Billing
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  subscriptionStatus   SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?

  // Legal / compliance
  signupIp      String?
  tosAcceptedAt DateTime?

  // Usage
  labelsThisMonth Int       @default(0)
  labelsTotal     Int       @default(0)
  lastRunAt       DateTime?

  // Fulfillment
  autoFulfillEnabled Boolean @default(true) // Mark orders as "Preparado" in Shopify after DAC shipment
  fulfillMode        String  @default("on") // "off" | "on" | "always" — always = force fulfill regardless of product/status

  // Consecutive order consolidation
  consolidateConsecutiveOrders Boolean @default(false) // When same customer places 2+ orders in window, 2nd+ = REMITENTE
  consolidationWindowMinutes   Int     @default(30)    // Window in minutes to look back for same-customer orders

  // Printing
  defaultPrinter   String?
  autoPrintEnabled Boolean @default(false)

  // AI Address Resolver — fallback for ambiguous deterministic resolutions
  aiResolverEnabled    Boolean @default(false) // opt-in per tenant
  aiResolverDailyLimit Int     @default(100)   // max AI calls per day
  aiResolverDailyUsed  Int     @default(0)     // reset daily at midnight UY
  aiResolverLastReset  DateTime?               // last time daily counter was reset

  user    User     @relation(fields: [userId], references: [id])
  jobs    Job[]
  labels  Label[]
  runLogs RunLog[]

  // Meta Ads
  metaAdAccount MetaAdAccount?

  // Recover (WhatsApp cart recovery)
  recoverConfig RecoverConfig?

  // AI Address Resolutions
  addressResolutions AddressResolution[]

  @@index([slug])
  @@index([stripeCustomerId])
  @@index([apiKey])
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

// --- JOBS ---

model Job {
  id         String     @id @default(cuid())
  tenantId   String
  bullJobId  String?    @unique
  type       JobType    @default(PROCESS_ORDERS)
  status     JobStatus  @default(PENDING)
  trigger    JobTrigger @default(CRON)
  startedAt  DateTime?
  finishedAt DateTime?
  durationMs Int?

  totalOrders  Int @default(0)
  successCount Int @default(0)
  failedCount  Int @default(0)
  skippedCount Int @default(0)

  // Agent-based bulk flow: Render generates xlsx, Agent (Adrian's Mac) uploads to DAC
  xlsxStoragePath String?
  agentPickedAt   DateTime?

  errorMessage String?
  createdAt    DateTime @default(now())

  tenant Tenant   @relation(fields: [tenantId], references: [id])
  labels Label[]
  logs   RunLog[]

  @@index([tenantId, createdAt(sort: Desc)])
}

enum JobType {
  PROCESS_ORDERS
  PROCESS_ORDERS_BULK
  RETRY_FAILED
  TEST_DAC
}

enum JobStatus {
  PENDING
  RUNNING
  WAITING_FOR_AGENT
  UPLOADING
  COMPLETED
  FAILED
  PARTIAL
}

enum JobTrigger {
  CRON
  WEBHOOK
  MANUAL
  MCP
  TEST
}

// --- LABELS ---

model Label {
  id               String      @id @default(cuid())
  tenantId         String
  jobId            String?
  shopifyOrderId   String
  shopifyOrderName String
  customerName     String
  customerEmail    String?
  customerPhone    String?
  deliveryAddress  String
  city             String
  department       String
  totalUyu         Float
  paymentType      PaymentType
  dacGuia          String?     @unique
  pdfPath          String?
  pdfUrl           String?
  status           LabelStatus @default(PENDING)
  errorMessage     String?
  emailSent        Boolean     @default(false)
  emailSentAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  job    Job?   @relation(fields: [jobId], references: [id])

  @@unique([tenantId, shopifyOrderId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([dacGuia])
}

enum LabelStatus {
  PENDING
  CREATED
  COMPLETED
  FAILED
  SKIPPED
  NEEDS_REVIEW
}

enum PaymentType {
  REMITENTE
  DESTINATARIO
}

// --- RUN LOGS ---

model RunLog {
  id        String   @id @default(cuid())
  tenantId  String
  jobId     String?
  level     LogLevel @default(INFO)
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  job    Job?   @relation(fields: [jobId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
}

enum LogLevel {
  INFO
  WARN
  ERROR
  SUCCESS
}

// --- META ADS AGENT ---

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  PAUSED_AUTO
  ERROR
  DELETED
}

model MetaAdAccount {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Meta API credentials (encrypted AES-256)
  metaAccessToken String? // Encrypted
  metaAdAccountId String? // e.g. act_123456
  metaPageId      String?
  metaPixelId     String?

  // Google Drive source
  driveFolderId String? // Root folder with creatives
  driveApiKey   String? // Encrypted

  // Notification settings
  notifyEmail   String?
  notifyWebhook String?

  // Config
  isActive        Boolean @default(false)
  scanSchedule    String  @default("0 8 * * 1-5") // weekdays 8am
  monitorSchedule String  @default("*/30 * * * *") // every 30min

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  rules        AdRule[]
  ads          ManagedAd[]
  uploadJobs   AdUploadJob[]
  monitorQueue AdMonitorQueue[]

  @@index([tenantId])
}

model AdRule {
  id              String   @id @default(cuid())
  metaAdAccountId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Rule config
  name        String
  metric      String // e.g. "purchase_intent_rate", "ctr", "cpc", "cpm"
  operator    String // "lt", "gt", "lte", "gte"
  threshold   Float
  windowHours Int     @default(48) // evaluation window
  action      String  @default("pause") // "pause" | "notify"
  isActive    Boolean @default(true)

  metaAdAccount MetaAdAccount @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)

  @@index([metaAdAccountId])
}

model ManagedAd {
  id              String   @id @default(cuid())
  metaAdAccountId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Meta references
  metaCampaignId String?
  metaAdSetId    String?
  metaAdId       String?
  metaCreativeId String?

  // Creative info
  creativeName String
  creativeType String  @default("IMAGE") // IMAGE | VIDEO
  driveFileId  String?
  headline     String?
  bodyText     String?
  callToAction String? @default("SHOP_NOW")
  linkUrl      String?

  // Status
  status        AdStatus  @default(PENDING)
  errorMessage  String?
  lastCheckedAt DateTime?

  // Latest metrics snapshot
  impressions        Int   @default(0)
  clicks             Int   @default(0)
  spend              Float @default(0)
  purchases          Int   @default(0)
  ctr                Float @default(0)
  cpc                Float @default(0)
  cpm                Float @default(0)
  roas               Float @default(0)
  purchaseIntentRate Float @default(0)

  metaAdAccount  MetaAdAccount      @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)
  metricsHistory AdMetricsHistory[]

  @@index([metaAdAccountId])
  @@index([metaAdId])
}

model AdMetricsHistory {
  id          String   @id @default(cuid())
  managedAdId String
  recordedAt  DateTime @default(now())

  impressions        Int   @default(0)
  clicks             Int   @default(0)
  spend              Float @default(0)
  purchases          Int   @default(0)
  ctr                Float @default(0)
  cpc                Float @default(0)
  cpm                Float @default(0)
  roas               Float @default(0)
  purchaseIntentRate Float @default(0)

  managedAd ManagedAd @relation(fields: [managedAdId], references: [id], onDelete: Cascade)

  @@index([managedAdId, recordedAt(sort: Desc)])
}

model AdUploadJob {
  id              String    @id @default(cuid())
  metaAdAccountId String
  status          JobStatus @default(PENDING)
  trigger         String    @default("MANUAL") // MANUAL | CRON
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?

  totalFiles   Int @default(0)
  successCount Int @default(0)
  failedCount  Int @default(0)
  skippedCount Int @default(0)

  errorMessage String?
  createdAt    DateTime @default(now())

  metaAdAccount MetaAdAccount @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)

  @@index([metaAdAccountId, createdAt(sort: Desc)])
  @@index([status])
}

model AdMonitorQueue {
  id              String    @id @default(cuid())
  metaAdAccountId String
  status          JobStatus @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  adsChecked      Int       @default(0)
  adsPaused       Int       @default(0)
  errorMessage    String?
  createdAt       DateTime  @default(now())

  metaAdAccount MetaAdAccount @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)

  @@index([metaAdAccountId, createdAt(sort: Desc)])
  @@index([status])
}

// --- RECOVER MODULE (WhatsApp Cart Recovery) ---

enum RecoverSubscriptionStatus {
  INACTIVE
  ACTIVE
  PAUSED
  CANCELLED
}

enum CartStatus {
  PENDING
  MESSAGE_1_SENT
  MESSAGE_2_SENT
  RECOVERED
  OPTED_OUT
  NO_PHONE
  FAILED
}

enum RecoverMessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model RecoverConfig {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription
  subscriptionId     String?
  subscriptionStatus RecoverSubscriptionStatus @default(INACTIVE)
  isActive           Boolean                   @default(false)

  // Timing
  delayMinutes              Int     @default(60)
  secondMessageEnabled      Boolean @default(false)
  secondMessageDelayMinutes Int     @default(1440)

  // Templates
  messageTemplate1 String @default("Hola {{1}}, notamos que dejaste {{2}} en tu carrito. Necesitas ayuda para completar tu compra? {{3}}")
  messageTemplate2 String @default("Ultimo aviso! Tu carrito con {{2}} todavia te espera {{3}}")

  // Opt-out
  optOutKeyword String @default("STOP")

  // WhatsApp credentials mode
  // "PLATFORM" = use AutoEnvia's shared number (env vars)
  // "OWN"      = tenant uses their own WhatsApp Business API credentials
  whatsappMode          String  @default("PLATFORM")
  whatsappApiToken      String? // encrypted, only used when whatsappMode = "OWN"
  whatsappPhoneNumberId String? // only used when whatsappMode = "OWN"

  // AI message generation (opt-in)
  // When true, Claude generates personalized messages instead of the static templates.
  // Falls back to static templates automatically if AI is unavailable.
  aiMessageEnabled Boolean @default(false)

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  carts   RecoverCart[]
  optOuts RecoverOptOut[]

  @@index([tenantId])
}

model RecoverCart {
  id        String   @id @default(cuid())
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Shopify checkout data
  shopifyCheckoutId    String
  shopifyCheckoutToken String
  customerPhone        String?
  customerName         String?
  customerEmail        String?
  cartTotal            Float?
  currency             String  @default("UYU")
  cartItems            Json    @default("[]")
  checkoutUrl          String?

  // Status tracking
  status           CartStatus @default(PENDING)
  recoveredAt      DateTime?
  recoveredOrderId String?

  // Relations
  recoverConfigId String

  recoverConfig RecoverConfig       @relation(fields: [recoverConfigId], references: [id], onDelete: Cascade)
  messageLogs   RecoverMessageLog[]
  jobs          RecoverJob[]

  @@unique([tenantId, shopifyCheckoutId])
  @@index([tenantId, status])
  @@index([shopifyCheckoutId])
}

model RecoverMessageLog {
  id        String   @id @default(cuid())
  cartId    String
  tenantId  String
  createdAt DateTime @default(now())

  messageNumber     Int
  phone             String
  messageBody       String
  whatsappMessageId String?
  status            RecoverMessageStatus @default(SENT)
  metaErrorCode     String?
  metaErrorMessage  String?

  cart RecoverCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([whatsappMessageId])
  @@index([tenantId, createdAt(sort: Desc)])
}

model RecoverOptOut {
  id        String   @id @default(cuid())
  tenantId  String
  phone     String
  createdAt DateTime @default(now())

  recoverConfigId String
  recoverConfig   RecoverConfig @relation(fields: [recoverConfigId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phone])
  @@index([tenantId, phone])
}

model RecoverJob {
  id        String   @id @default(cuid())
  tenantId  String
  cartId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messageNumber Int
  status        JobStatus @default(PENDING)
  scheduledFor  DateTime
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?

  cart RecoverCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, messageNumber])
  @@index([status, scheduledFor])
  @@index([tenantId])
  @@index([cartId])
}

// --- AI ADDRESS RESOLVER ---
// Cache + audit log for AI-resolved ambiguous delivery addresses.
// Populated when deterministic rules in shipment.ts cannot resolve with high confidence.

enum ResolutionSource {
  DETERMINISTIC
  AI
  CACHE
}

enum ResolutionConfidence {
  HIGH
  MEDIUM
  LOW
}

model AddressResolution {
  id       String @id @default(cuid())
  tenantId String

  // Cache key: sha256(normalized city + address1 + address2 + zip), first 16 chars
  inputHash String

  // Raw inputs (for debugging and prompt tuning)
  rawCity     String
  rawAddress1 String
  rawAddress2 String?
  rawZip      String?
  rawProvince String?

  // Resolved output used by DAC form filler
  resolvedBarrio          String? // null if not Montevideo or not detectable
  resolvedCity            String
  resolvedDepartment      String
  resolvedDeliveryAddress String  // clean street + number, no extras
  resolvedObs             String  @default("") // apto, piso, references, etc.

  // Metadata
  source      ResolutionSource
  confidence  ResolutionConfidence
  aiModel     String? // e.g. "claude-haiku-4-5-20251001"
  aiReasoning String? // AI's own explanation for audit
  aiCostUsd   Float?  // cost of this single call

  // Feedback from DAC processing (updated post-label)
  dacAccepted Boolean? // null=pending, true=worked, false=rejected
  dacGuia     String?  // guia if successful
  dacError    String?  // error if rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, inputHash])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([inputHash])
  @@index([dacAccepted])
  @@index([source])
}
