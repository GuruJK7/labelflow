// ─────────────────────────────────────────────────────────────────────────────
// DUAL-SCHEMA WARNING — keep apps/web/prisma/schema.prisma and
// apps/worker/prisma/schema.prisma BYTE-IDENTICAL. Both apps share the same
// Supabase database and must generate equivalent Prisma Client types. Drift
// has broken the Render worker build twice (2026-04-19, 2026-04-22).
//
// After editing this file, run from repo root:
//   npm run sync-schemas    # copies this file to apps/worker/prisma/
//   npm run check-schemas   # verifies they match
//
// `npm run build` at the repo root also auto-runs check-schemas.
// Source of truth: apps/web/prisma/schema.prisma (edit here; never edit the
// worker copy directly).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- AUTH ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  tenant   Tenant?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- TENANT ---

model Tenant {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  slug      String   @unique
  apiKey    String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Shopify
  shopifyStoreUrl String?
  shopifyToken    String? // Encrypted AES-256

  // DAC
  dacUsername String?
  dacPassword String? // Encrypted AES-256

  // Email
  emailHost String?
  emailPort Int?    @default(587)
  emailUser String?
  emailPass String? // Encrypted AES-256
  emailFrom String?
  storeName String?

  // Config
  paymentThreshold    Float   @default(4000)
  paymentRuleEnabled  Boolean @default(false)
  cronSchedule        String  @default("*/15 * * * *")
  scheduleSlots       Json?   // [{ time: "09:00", maxOrders: 0 }] — 0 means unlimited
  timezone            String  @default("America/Montevideo")
  maxOrdersPerRun     Int     @default(20)
  isActive            Boolean @default(false)

  // Order processing
  orderSortDirection  String  @default("oldest_first")
  allowedProductTypes Json?
  productTypeCache    Json?

  // Stripe Billing (legacy — USD recurring; nuevos tenants no usan este flujo).
  // El modelo activo es credit-packs (ver shipmentCredits abajo). Suscripciones
  // MP existentes se honran hasta currentPeriodEnd y luego transicionan a packs.
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  subscriptionStatus   SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?

  // Legal / compliance
  signupIp      String?
  tosAcceptedAt DateTime?

  // Usage
  labelsThisMonth Int       @default(0)
  labelsTotal     Int       @default(0)
  lastRunAt       DateTime?

  // ── CREDIT-PACK BILLING (modelo activo, reemplaza al de suscripciones) ──
  //
  // shipmentCredits: saldo de envíos disponibles. El worker decrementa por
  //   cada Finalizar exitoso en DAC. Si llega a 0, el scheduler deja de
  //   encolar jobs para este tenant (gate en apps/worker/src/jobs/scheduler.ts).
  //
  // Welcome bonus: el default de 10 garantiza que cualquier tenant nuevo
  //   arranca con 10 envíos gratis sin código en la ruta de signup. Tenants
  //   pre-existentes a esta migración mantienen 0 hasta que se les hace
  //   backfill (script aparte) — ver TRANSITION_NOTES en credit-packs.ts.
  //
  // creditsPurchased / creditsConsumed: contadores acumulativos lifetime,
  //   solo para audit y métricas admin. NO se usan para gating.
  //
  // PCI / fraude: los créditos NO caducan. Si hay refund/chargeback, el
  //   handler en apps/web/app/api/webhooks/mercadopago/route.ts intenta
  //   debitar; si el saldo ya se gastó, queda registrado en log y se tolera.
  shipmentCredits  Int @default(10)
  creditsPurchased Int @default(0)
  creditsConsumed  Int @default(0)

  // ── REFERIDOS ──
  //
  // referralCode: código único que el tenant comparte (URL ?ref=<code>).
  //   Se genera en signup. Nullable para tenants pre-migración hasta backfill.
  //
  // referredByCode / referredById: a quién pertenece este referido. Se
  //   capturan en signup leyendo cookie firmada. SetNull si referrer se borra.
  //
  // referralCreditsEarned: contador acumulativo lifetime de envíos GRATIS
  //   ganados como referidor (audit). El crédito real vive en shipmentCredits.
  referralCode          String? @unique
  referredByCode        String?
  referredById          String?
  referrer              Tenant? @relation("TenantReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals             Tenant[] @relation("TenantReferrals")
  referralCreditsEarned Int     @default(0)

  // Fulfillment
  autoFulfillEnabled Boolean @default(true) // Mark orders as "Preparado" in Shopify after DAC shipment
  fulfillMode        String  @default("on") // "off" | "on" | "always" — always = force fulfill regardless of product/status

  // Consecutive order consolidation
  consolidateConsecutiveOrders Boolean @default(false) // When same customer places 2+ orders in window, 2nd+ = REMITENTE
  consolidationWindowMinutes   Int     @default(30)    // Window in minutes to look back for same-customer orders

  // Auto payment on DAC (Plexo gateway) for REMITENTE shipments
  // When enabled, worker drives the Plexo "saved-card + CVC" flow after clicking
  // Finalizar. Requires paymentRuleEnabled (or a ShippingRule) to produce REMITENTE.
  // PCI NOTE: storing CVC (even encrypted) is a PCI DSS 3.2 violation. Tenant
  // accepts responsibility by toggling paymentAutoEnabled. See settings UI.
  paymentAutoEnabled Boolean @default(false)
  paymentCardBrand   String? // "mastercard" | "visa" | "oca" — which brand tile to click on Plexo
  paymentCardLast4   String? // e.g. "3294" — used to find the right saved-card radio
  paymentCardCvc     String? // AES-256-GCM encrypted

  // Printing
  defaultPrinter   String?
  autoPrintEnabled Boolean @default(false)

  // AI Address Resolver — fallback for ambiguous deterministic resolutions
  aiResolverEnabled    Boolean @default(true)  // on by default; opt-out per tenant
  aiResolverDailyLimit Int     @default(100)   // max AI calls per day
  aiResolverDailyUsed  Int     @default(0)     // reset daily at midnight UY
  aiResolverLastReset  DateTime?               // last time daily counter was reset

  user    User     @relation(fields: [userId], references: [id])
  jobs    Job[]
  labels  Label[]
  runLogs RunLog[]

  // Meta Ads
  metaAdAccount MetaAdAccount?

  // Recover (WhatsApp cart recovery)
  recoverConfig RecoverConfig?

  // AI Address Resolutions
  addressResolutions AddressResolution[]

  // Shipping rules (first-match-wins rule engine for REMITENTE/DESTINATARIO selection)
  shippingRules ShippingRule[]

  // H-9: DAC session cookies (AES-encrypted), one row per tenant
  dacSession DacSession?

  // Credit-pack billing
  creditPurchases       CreditPurchase[]
  // Referrals: this tenant as referrer (received credits) / as referee (paid)
  referralAccrualsRecv  ReferralCreditAccrual[] @relation("ReferralAccrualReferrer")
  referralAccrualsPaid  ReferralCreditAccrual[] @relation("ReferralAccrualReferee")

  @@index([slug])
  @@index([stripeCustomerId])
  @@index([apiKey])
  @@index([referralCode])
  @@index([referredById])
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

// --- JOBS ---

model Job {
  id         String     @id @default(cuid())
  tenantId   String
  bullJobId  String?    @unique
  type       JobType    @default(PROCESS_ORDERS)
  status     JobStatus  @default(PENDING)
  trigger    JobTrigger @default(CRON)
  startedAt  DateTime?
  finishedAt DateTime?
  durationMs Int?

  totalOrders  Int @default(0)
  successCount Int @default(0)
  failedCount  Int @default(0)
  skippedCount Int @default(0)

  // Agent-based bulk flow: Render generates xlsx, Agent (Adrian's Mac) uploads to DAC
  xlsxStoragePath String?
  agentPickedAt   DateTime?

  errorMessage String?
  createdAt    DateTime @default(now())

  tenant Tenant   @relation(fields: [tenantId], references: [id])
  labels Label[]
  logs   RunLog[]

  @@index([tenantId, createdAt(sort: Desc)])
}

enum JobType {
  PROCESS_ORDERS
  PROCESS_ORDERS_BULK
  RETRY_FAILED
  TEST_DAC
}

enum JobStatus {
  PENDING
  RUNNING
  WAITING_FOR_AGENT
  UPLOADING
  COMPLETED
  FAILED
  PARTIAL
}

enum JobTrigger {
  CRON
  WEBHOOK
  MANUAL
  MCP
  TEST
}

// --- LABELS ---

model Label {
  id               String      @id @default(cuid())
  tenantId         String
  jobId            String?
  shopifyOrderId   String
  shopifyOrderName String
  customerName     String
  customerEmail    String?
  customerPhone    String?
  deliveryAddress  String
  city             String
  department       String
  totalUyu         Float
  paymentType      PaymentType
  // Auto-payment outcome on the DAC/Plexo side. Relevant only when
  // paymentType = REMITENTE AND tenant.paymentAutoEnabled = true.
  // Values:
  //   "not_required"     — DESTINATARIO (customer pays COD) or auto-pay off
  //   "paid"             — Plexo confirmed charge + redirect back to DAC ok
  //   "pending_manual"   — needs human to complete payment (3DS, timeout, etc.)
  //   "failed_rejected"  — Plexo explicitly rejected (bad CVC, no funds, etc.)
  paymentStatus        String?   @default("not_required")
  paymentFailureReason String?   // "3ds_required" | "card_rejected" | "timeout" | "saved_card_not_found" | "selector_failure"
  paymentAttemptedAt   DateTime?
  dacGuia          String?     @unique
  pdfPath          String?
  pdfUrl           String?
  status           LabelStatus @default(PENDING)
  errorMessage     String?
  emailSent        Boolean     @default(false)
  emailSentAt      DateTime?

  // M-2 (2026-04-21 audit): reconcile used to count "auto-retry:<orderName>"
  // entries in RunLog with a `contains` substring scan to decide whether a
  // FAILED label had already been auto-retried the maximum number of times.
  // The scan grew linearly with RunLog (millions of rows on busy tenants)
  // and had a false-match footgun whenever a log message happened to
  // contain another order's name as a prefix/suffix. Replaced by this
  // structured counter: reconcile bumps it when it resets a FAILED label,
  // the success path resets it to 0 when a retry succeeds, and the cap
  // check becomes an O(1) field compare. Legacy FAILED labels start at
  // 0 — worst case they get MAX_AUTO_RETRIES extra attempts the first
  // time reconcile sees them after the migration, which is an acceptable
  // one-time blip.
  autoRetryCount   Int         @default(0)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  job    Job?   @relation(fields: [jobId], references: [id])

  @@unique([tenantId, shopifyOrderId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([dacGuia])
}

enum LabelStatus {
  PENDING
  CREATED
  COMPLETED
  FAILED
  SKIPPED
  NEEDS_REVIEW
}

enum PaymentType {
  REMITENTE
  DESTINATARIO
}

// --- RUN LOGS ---

model RunLog {
  id        String   @id @default(cuid())
  tenantId  String
  jobId     String?
  level     LogLevel @default(INFO)
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  job    Job?   @relation(fields: [jobId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
}

enum LogLevel {
  INFO
  WARN
  ERROR
  SUCCESS
}

// --- META ADS AGENT ---

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  PAUSED_AUTO
  ERROR
  DELETED
}

model MetaAdAccount {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Meta API credentials (encrypted AES-256)
  metaAccessToken String? // Encrypted
  metaAdAccountId String? // e.g. act_123456
  metaPageId      String?
  metaPixelId     String?

  // Google Drive source
  driveFolderId String? // Root folder with creatives
  driveApiKey   String? // Encrypted

  // Notification settings
  notifyEmail   String?
  notifyWebhook String?

  // Config
  isActive        Boolean @default(false)
  scanSchedule    String  @default("0 8 * * 1-5") // weekdays 8am
  monitorSchedule String  @default("*/30 * * * *") // every 30min

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  rules        AdRule[]
  ads          ManagedAd[]
  uploadJobs   AdUploadJob[]
  monitorQueue AdMonitorQueue[]

  @@index([tenantId])
}

model AdRule {
  id              String   @id @default(cuid())
  metaAdAccountId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Rule config
  name        String
  metric      String // e.g. "purchase_intent_rate", "ctr", "cpc", "cpm"
  operator    String // "lt", "gt", "lte", "gte"
  threshold   Float
  windowHours Int     @default(48) // evaluation window
  action      String  @default("pause") // "pause" | "notify"
  isActive    Boolean @default(true)

  metaAdAccount MetaAdAccount @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)

  @@index([metaAdAccountId])
}

model ManagedAd {
  id              String   @id @default(cuid())
  metaAdAccountId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Meta references
  metaCampaignId String?
  metaAdSetId    String?
  metaAdId       String?
  metaCreativeId String?

  // Creative info
  creativeName String
  creativeType String  @default("IMAGE") // IMAGE | VIDEO
  driveFileId  String?
  headline     String?
  bodyText     String?
  callToAction String? @default("SHOP_NOW")
  linkUrl      String?

  // Status
  status        AdStatus  @default(PENDING)
  errorMessage  String?
  lastCheckedAt DateTime?

  // Latest metrics snapshot
  impressions        Int   @default(0)
  clicks             Int   @default(0)
  spend              Float @default(0)
  purchases          Int   @default(0)
  ctr                Float @default(0)
  cpc                Float @default(0)
  cpm                Float @default(0)
  roas               Float @default(0)
  purchaseIntentRate Float @default(0)

  metaAdAccount  MetaAdAccount      @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)
  metricsHistory AdMetricsHistory[]

  @@index([metaAdAccountId])
  @@index([metaAdId])
}

model AdMetricsHistory {
  id          String   @id @default(cuid())
  managedAdId String
  recordedAt  DateTime @default(now())

  impressions        Int   @default(0)
  clicks             Int   @default(0)
  spend              Float @default(0)
  purchases          Int   @default(0)
  ctr                Float @default(0)
  cpc                Float @default(0)
  cpm                Float @default(0)
  roas               Float @default(0)
  purchaseIntentRate Float @default(0)

  managedAd ManagedAd @relation(fields: [managedAdId], references: [id], onDelete: Cascade)

  @@index([managedAdId, recordedAt(sort: Desc)])
}

model AdUploadJob {
  id              String    @id @default(cuid())
  metaAdAccountId String
  status          JobStatus @default(PENDING)
  trigger         String    @default("MANUAL") // MANUAL | CRON
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?

  totalFiles   Int @default(0)
  successCount Int @default(0)
  failedCount  Int @default(0)
  skippedCount Int @default(0)

  errorMessage String?
  createdAt    DateTime @default(now())

  metaAdAccount MetaAdAccount @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)

  @@index([metaAdAccountId, createdAt(sort: Desc)])
  @@index([status])
}

model AdMonitorQueue {
  id              String    @id @default(cuid())
  metaAdAccountId String
  status          JobStatus @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  adsChecked      Int       @default(0)
  adsPaused       Int       @default(0)
  errorMessage    String?
  createdAt       DateTime  @default(now())

  metaAdAccount MetaAdAccount @relation(fields: [metaAdAccountId], references: [id], onDelete: Cascade)

  @@index([metaAdAccountId, createdAt(sort: Desc)])
  @@index([status])
}

// --- RECOVER MODULE (WhatsApp Cart Recovery) ---

enum RecoverSubscriptionStatus {
  INACTIVE
  ACTIVE
  PAUSED
  CANCELLED
}

enum CartStatus {
  PENDING
  MESSAGE_1_SENT
  MESSAGE_2_SENT
  RECOVERED
  OPTED_OUT
  NO_PHONE
  FAILED
}

enum RecoverMessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model RecoverConfig {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription
  subscriptionId     String?
  subscriptionStatus RecoverSubscriptionStatus @default(INACTIVE)
  isActive           Boolean                   @default(false)

  // Timing
  delayMinutes              Int     @default(60)
  secondMessageEnabled      Boolean @default(false)
  secondMessageDelayMinutes Int     @default(1440)

  // Templates
  messageTemplate1 String @default("Hola {{1}}, notamos que dejaste {{2}} en tu carrito. Necesitas ayuda para completar tu compra? {{3}}")
  messageTemplate2 String @default("Ultimo aviso! Tu carrito con {{2}} todavia te espera {{3}}")

  // Opt-out
  optOutKeyword String @default("STOP")

  // WhatsApp credentials mode
  // "PLATFORM" = use AutoEnvia's shared number (env vars)
  // "OWN"      = tenant uses their own WhatsApp Business API credentials
  whatsappMode          String  @default("PLATFORM")
  whatsappApiToken      String? // encrypted, only used when whatsappMode = "OWN"
  whatsappPhoneNumberId String? // only used when whatsappMode = "OWN"

  // AI message generation (opt-in)
  // When true, Claude generates personalized messages instead of the static templates.
  // Falls back to static templates automatically if AI is unavailable.
  aiMessageEnabled Boolean @default(false)

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  carts   RecoverCart[]
  optOuts RecoverOptOut[]

  @@index([tenantId])
}

model RecoverCart {
  id        String   @id @default(cuid())
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Shopify checkout data
  shopifyCheckoutId    String
  shopifyCheckoutToken String
  customerPhone        String?
  customerName         String?
  customerEmail        String?
  cartTotal            Float?
  currency             String  @default("UYU")
  cartItems            Json    @default("[]")
  checkoutUrl          String?

  // Status tracking
  status           CartStatus @default(PENDING)
  recoveredAt      DateTime?
  recoveredOrderId String?

  // Relations
  recoverConfigId String

  recoverConfig RecoverConfig       @relation(fields: [recoverConfigId], references: [id], onDelete: Cascade)
  messageLogs   RecoverMessageLog[]
  jobs          RecoverJob[]

  @@unique([tenantId, shopifyCheckoutId])
  @@index([tenantId, status])
  @@index([shopifyCheckoutId])
}

model RecoverMessageLog {
  id        String   @id @default(cuid())
  cartId    String
  tenantId  String
  createdAt DateTime @default(now())

  messageNumber     Int
  phone             String
  messageBody       String
  whatsappMessageId String?
  status            RecoverMessageStatus @default(SENT)
  metaErrorCode     String?
  metaErrorMessage  String?

  cart RecoverCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([whatsappMessageId])
  @@index([tenantId, createdAt(sort: Desc)])
}

model RecoverOptOut {
  id        String   @id @default(cuid())
  tenantId  String
  phone     String
  createdAt DateTime @default(now())

  recoverConfigId String
  recoverConfig   RecoverConfig @relation(fields: [recoverConfigId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phone])
  @@index([tenantId, phone])
}

model RecoverJob {
  id        String   @id @default(cuid())
  tenantId  String
  cartId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messageNumber Int
  status        JobStatus @default(PENDING)
  scheduledFor  DateTime
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?

  cart RecoverCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, messageNumber])
  @@index([status, scheduledFor])
  @@index([tenantId])
  @@index([cartId])
}

// --- AI ADDRESS RESOLVER ---
// Cache + audit log for AI-resolved ambiguous delivery addresses.
// Populated when deterministic rules in shipment.ts cannot resolve with high confidence.

enum ResolutionSource {
  DETERMINISTIC
  AI
  CACHE
}

enum ResolutionConfidence {
  HIGH
  MEDIUM
  LOW
}

model AddressResolution {
  id       String @id @default(cuid())
  tenantId String

  // Cache key: sha256(normalized city + address1 + address2 + zip), first 16 chars
  inputHash String

  // Raw inputs (for debugging and prompt tuning)
  rawCity     String
  rawAddress1 String
  rawAddress2 String?
  rawZip      String?
  rawProvince String?

  // Resolved output used by DAC form filler
  resolvedBarrio          String? // null if not Montevideo or not detectable
  resolvedCity            String
  resolvedDepartment      String
  resolvedDeliveryAddress String  // clean street + number, no extras
  resolvedObs             String  @default("") // apto, piso, references, etc.

  // Metadata
  source      ResolutionSource
  confidence  ResolutionConfidence
  aiModel     String? // e.g. "claude-haiku-4-5-20251001"
  aiReasoning String? // AI's own explanation for audit
  aiCostUsd   Float?  // cost of this single call

  // Feedback from DAC processing (updated post-label)
  dacAccepted Boolean? // null=pending, true=worked, false=rejected
  dacGuia     String?  // guia if successful
  dacError    String?  // error if rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // H-2 (2026-04-21 audit): TTL on cache entries.
  //
  // Without an expiry, an address that resolved CORRECTLY last year keeps
  // getting served from cache forever — but DAC department boundaries,
  // postal codes, and the MVD_STREET_RANGES dictionary drift over time,
  // and cached "Italia 4500 → Montevideo/Pocitos" can silently become
  // stale the day we update the ranges. The dacAccepted feedback loop
  // catches entries that fail at DAC, but not entries that DAC accepts
  // yet deliver to the wrong barrio. Forcing a refresh after N days
  // bounds that blast radius. Nullable so legacy rows (pre-H-2) don't
  // need a backfill — the reader treats null as "no expiry set, treat
  // as the default TTL from createdAt".
  expiresAt DateTime?

  @@unique([tenantId, inputHash])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([inputHash])
  @@index([dacAccepted])
  @@index([source])
  @@index([expiresAt]) // cleanup sweeper scans by expiry
}

// --- WEBHOOK IDEMPOTENCY ---
//
// C-3 (2026-04-21 audit): Shopify retries webhooks aggressively (every 5
// minutes for 48h) if we take too long to respond or return 5xx. Without
// idempotency, a legitimate-but-slow response to `orders/paid` for the same
// order can enqueue the processing job N times, leading to duplicate labels
// in DAC (the ordered classifier runs before we hit the "already shipped"
// guard, so each run can call Shopify and potentially create duplicate
// guías).
//
// Shopify sets `X-Shopify-Webhook-Id` (a stable UUID per webhook delivery).
// We INSERT a row here keyed on (topic, webhookId) before enqueuing the job;
// a unique-violation means "already seen this delivery — ACK 200 and do
// nothing."
model WebhookReceipt {
  id         String   @id @default(cuid())
  source     String   // 'shopify' | 'mercadopago' | 'whatsapp' | 'stripe' — scope the (topic, id) namespace
  topic      String   // e.g. 'orders/paid' or 'checkouts/update'
  webhookId  String   // X-Shopify-Webhook-Id (or equivalent for other sources)
  shopDomain String?  // 'acme.myshopify.com' — helpful for debugging, not part of the unique key
  tenantId   String?  // nullable: webhook may arrive for an unknown tenant
  receivedAt DateTime @default(now())

  @@unique([source, topic, webhookId]) // the idempotency key
  @@index([receivedAt]) // for cleanup sweeper
  @@index([tenantId, receivedAt(sort: Desc)])
}

// --- DAC SESSION ---
//
// H-9 (2026-04-21 audit): DAC session cookies used to live in a generic
// RunLog row with `message = 'dac_cookies'` and `meta = { ... }` as plain
// JSON. Two problems:
//   1. Cookies include DAC session tokens — equivalent to login credentials
//      for anyone with DB read access. Plaintext storage violated the
//      "encrypt credentials at rest" rule the rest of the codebase follows.
//   2. Storing in RunLog meant the row was treated as a generic log and
//      could be swept by retention policies that would accidentally
//      invalidate the session.
//
// The dedicated model holds an encrypted JSON blob (AES-256-GCM via the
// same helpers used for shopifyToken/dacPassword) with a one-row-per-tenant
// invariant. `savedAt` replaces the RunLog createdAt used for the 4-hour
// expiry check.
model DacSession {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  cookiesEncrypted String   // AES-256-GCM ciphertext of JSON.stringify(cookies[])
  savedAt          DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([savedAt])
}

// --- PENDING SHIPMENT (duplicate-guia defense) ---
//
// C-4 (2026-04-21 audit): DAC's Finalizar click is irreversible — once it
// fires, the guía exists in DAC's system. If the worker crashes (OOM,
// SIGTERM from a deploy, browser target-closed) between the click and our
// successful extraction from the confirmation page, we end up with a
// PENDING-{timestamp} placeholder in Label.dacGuia and a REAL guía in DAC
// with no local record. Retrying the order then creates a second DAC
// shipment — the customer gets two labels, pays double, and we get a
// support ticket.
//
// The defense is a pre-click marker: before clicking Finalizar, INSERT a
// row here keyed on (tenantId, shopifyOrderId). The unique constraint
// makes "has this order already been submitted?" a single SELECT. On
// rerun, if a PENDING row exists, refuse to re-submit and surface the
// label as NEEDS_REVIEW so a human can confirm against DAC historial.
//
// Once extraction succeeds we set status=RESOLVED + resolvedGuia. The
// reconcile step 2 (runs every 10 min) picks up rows that stayed PENDING
// for > 10 min and marks them ORPHANED — those are the ones that need
// the operator to manually look up DAC historial and either attach the
// real guía to the Label or confirm no shipment was created.
model PendingShipment {
  id                String                @id @default(cuid())
  tenantId          String
  shopifyOrderId    String
  labelId           String?               // set once the Label row is known
  idempotencyKey    String                @unique // sha256(tenantId + shopifyOrderId)
  submitAttemptedAt DateTime              @default(now())
  resolvedAt        DateTime?
  resolvedGuia      String?               // set when status=RESOLVED
  status            PendingShipmentStatus @default(PENDING)
  errorNote         String?               // operator note on how it was fulfilled

  @@unique([tenantId, shopifyOrderId])
  @@index([status, submitAttemptedAt])
  @@index([tenantId, submitAttemptedAt(sort: Desc)])
}

enum PendingShipmentStatus {
  PENDING   // Finalizar clicked, guía extraction still in-flight or failed
  RESOLVED  // extraction succeeded; resolvedGuia is the real DAC guía
  ORPHANED  // stayed PENDING past threshold — operator must reconcile manually
}

// --- CLASSIFIER METRICS (observability) ---
//
// O-1 (2026-04-21 audit): day-grained counters of how the order classifier
// split each bulk run into GREEN / YELLOW / RED. Before this, "what
// fraction of orders are we auto-shipping vs. queueing for review?" had
// to be reconstructed by scanning RunLog — linear in log size and
// vulnerable to message-format drift. This table gives a single row per
// (tenantId, dayYmd) with counters that are atomically incremented on
// every bulk run.
//
// `dayYmd` is a UY-local date string (YYYY-MM-DD) built via the
// `localYmd()` helper — see M-7. Using a local string as the day key is
// intentional: a midnight-crossing run in UY should show up in the
// corresponding UY day, not the adjacent UTC day the operator doesn't
// think of.
model ClassifierMetric {
  id        String   @id @default(cuid())
  tenantId  String
  dayYmd    String   // UY-local YYYY-MM-DD
  green     Int      @default(0)
  yellow    Int      @default(0)
  red       Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([tenantId, dayYmd])
  @@index([tenantId, dayYmd])
}

// --- DAC PROCESSING LEASE (cross-worker serialization) ---
//
// Fase 3 (2026-04-21 audit): serialize DAC processing per tenant across
// multiple worker processes.
//
// C-6 already makes job claiming atomic (`FOR UPDATE SKIP LOCKED`), so two
// workers can't claim the same Job row. But the scheduler's dedup check —
// "don't create a PENDING job if one already exists for this tenant" — is
// racy: two scheduler instances running the same minute can both see "no
// pending job" and both INSERT, producing two valid PENDING jobs for the
// same tenant. C-6 then claims each job by a different worker, and both
// log into the same DAC account concurrently. DAC enforces a single
// active session per user, so this causes login loops, half-submitted
// forms, and in the worst case duplicate guías (C-4 catches the duplicate
// guía, but not the login thrash).
//
// This table is a distributed mutex keyed on tenantId with TTL semantics:
//   - Acquire = INSERT (first win) OR UPDATE WHERE expiresAt < NOW()
//     (take over from a dead holder).
//   - Heartbeat = bump expiresAt every ~2 min during the run so a live
//     holder never looks dead.
//   - Release = DELETE WHERE holderId = mine, in finally.
//
// If acquire fails (lock held by someone else), the job is re-queued to
// PENDING and another poll cycle will pick it up after the holder releases.
//
// Edge cases handled:
//   - Process crash mid-run: lease expires after TTL, next worker can take
//     over. Leaves the Job in RUNNING — reconcile.job step 3 picks that up.
//   - Same worker picks the same tenant twice (shouldn't happen with C-6,
//     but defensive): acquire returns true because holderId matches in the
//     expired-takeover path.
model DacProcessingLease {
  tenantId   String   @id
  holderId   String   // "hostname#pid#random8" — identifies the worker instance
  jobId      String?  // the Job this lease was acquired for (audit trail)
  acquiredAt DateTime @default(now())
  expiresAt  DateTime // bumped by the heartbeat timer every HEARTBEAT_MS

  @@index([expiresAt])      // sweeper / takeover queries scan by expiry
  @@index([holderId])       // ops queries: "what does worker X hold right now?"
}

// --- GDPR COMPLIANCE (Shopify mandatory privacy webhooks) ---
//
// C-5 (2026-04-21 audit): Shopify requires every app listed in the App
// Store to implement three privacy webhooks with signed HMAC verification:
//
//   - customers/data_request — a customer (via the merchant) requests an
//     export of their personal data. We have 30 days to respond.
//   - customers/redact       — a merchant requests deletion of a specific
//     customer's data. We have 30 days to delete.
//   - shop/redact            — 48 hours after app uninstall, Shopify asks
//     us to delete all data for the shop. We have 30 days to comply.
//
// The route handler signs the request off as received (HMAC + idempotency)
// and persists the payload here. Actual fulfillment (data export email,
// record deletion) is tracked via `status` and `fulfilledAt` so the
// operator can audit the compliance trail without scraping logs.
//
// payload is the raw JSON body Shopify sent — keep it as-is for audit even
// if the shape changes later.
model GdprRequest {
  id           String            @id @default(cuid())
  topic        GdprRequestTopic
  shopDomain   String
  tenantId     String?           // nullable — shop/redact can arrive AFTER uninstall
  customerId   String?           // present on customers/* events
  customerEmail String?          // present on customers/* events, useful for ops
  payload      Json              // the raw webhook body — source of truth for audit
  webhookId    String?           // X-Shopify-Webhook-Id — cross-ref with WebhookReceipt
  status       GdprRequestStatus @default(PENDING)
  receivedAt   DateTime          @default(now())
  fulfilledAt  DateTime?         // when we finished the data export / deletion
  notes        String?           // operator notes on how it was fulfilled

  @@index([status, receivedAt])
  @@index([tenantId, receivedAt(sort: Desc)])
  @@index([shopDomain, receivedAt(sort: Desc)])
}

enum GdprRequestTopic {
  CUSTOMERS_DATA_REQUEST
  CUSTOMERS_REDACT
  SHOP_REDACT
}

enum GdprRequestStatus {
  PENDING      // received — waiting for operator / sweep to fulfill
  FULFILLED    // data exported / deleted
  FAILED       // fulfillment errored; see `notes`
}

// --- SHIPPING RULES ---
//
// Ordered list of per-tenant rules that decide whether an order ships as
// REMITENTE (store pays with DAC account) or DESTINATARIO (customer pays COD).
//
// Evaluation: rules are sorted by `priority` ascending and evaluated top-to-bottom.
// The FIRST rule whose `ruleType` + `config` matches the order wins and sets the
// payment type. If no rule matches, the worker falls back to the legacy
// paymentRuleEnabled + paymentThreshold + consolidateConsecutiveOrders tenant
// fields so existing tenants keep working without creating any rules.
//
// `config` is JSON because each `ruleType` has its own schema; validation lives
// in apps/web/lib/shipping-rules.ts and apps/worker/src/rules/shipping.ts.
model ShippingRule {
  id        String   @id @default(cuid())
  tenantId  String
  name      String                           // human label, shown in dashboard
  ruleType  ShippingRuleType
  config    Json                             // rule-specific params (see types in code)
  priority  Int      @default(100)           // lower = evaluated earlier
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, priority])
  @@index([tenantId, isActive])
}

enum ShippingRuleType {
  THRESHOLD_TOTAL      // if order total (UYU) > minTotalUyu → REMITENTE
  CONSECUTIVE_ORDERS   // if same customer ordered within windowMinutes → REMITENTE
  NTH_SHIPMENT_FREE    // every Nth shipment to same customer → REMITENTE
  CUSTOMER_TAG         // if Shopify order/customer has tag → REMITENTE
  ITEM_COUNT           // if order has more than minItems line items → REMITENTE
}

// --- CREDIT PACKS (pay-as-you-go) ---
//
// CreditPurchase: una fila por intento de compra de pack. Se crea con
// status=PENDING al iniciar el checkout y se transiciona a PAID cuando
// MercadoPago confirma el pago via webhook (idempotente vía mpPaymentId
// único). Al pasar a PAID se incrementa Tenant.shipmentCredits y, si el
// tenant fue referido, se crea una ReferralCreditAccrual y se le acredita
// 20% al referidor.
//
// Diseño:
//   - mpExternalRef único: el formato es `pkg|<purchaseId>` y se pasa a
//     MercadoPago como external_reference, que vuelve en el webhook —
//     evita lookups por payerEmail/preferenceId frágiles.
//   - mpPaymentId único: garantiza idempotencia frente a webhooks
//     reintentados de MP (que reintenta agresivamente).
//   - status separado del flag de acreditación: el handler actualiza
//     ambos en una sola transacción para que no quede plata sin créditos
//     ni créditos sin plata.
model CreditPurchase {
  id                  String               @id @default(cuid())
  tenantId            String
  packId              String                                  // 'pack_10' | ... | 'pack_1000'
  shipments           Int                                     // 10 / 50 / 100 / 250 / 500 / 1000
  pricePerShipmentUyu Float                                   // 20 / 17 / 15 / 12 / 10 / 7
  totalPriceUyu       Float                                   // shipments * pricePer
  status              CreditPurchaseStatus @default(PENDING)
  mpPreferenceId      String?              @unique            // creado al iniciar checkout
  mpPaymentId         String?              @unique            // dado por webhook payment.approved
  mpExternalRef       String               @unique            // `pkg|<purchaseId>` — match key del webhook
  paidAt              DateTime?
  refundedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referralCredit ReferralCreditAccrual?

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([status])
}

enum CreditPurchaseStatus {
  PENDING        // checkout creado, esperando confirmación de pago
  PAID           // MP confirmó: créditos acreditados al tenant
  FAILED         // MP rechazó el pago
  REFUNDED       // chargeback / reembolso manual
}

// ReferralCreditAccrual: acreditación de 20% al referidor cuando un
// referido COMPRA un pack. Una fila por compra (sourcePurchaseId único)
// previene doble-acreditación si el webhook MP se procesa dos veces.
model ReferralCreditAccrual {
  id               String   @id @default(cuid())
  referrerTenantId String                                 // recibe créditos gratis
  refereeTenantId  String                                 // hizo la compra
  sourcePurchaseId String   @unique                       // 1 acreditación por compra
  shipmentsAccrued Int                                    // floor(0.2 * shipments comprados)
  createdAt        DateTime @default(now())

  referrer       Tenant         @relation("ReferralAccrualReferrer", fields: [referrerTenantId], references: [id], onDelete: Cascade)
  referee        Tenant         @relation("ReferralAccrualReferee",  fields: [refereeTenantId],  references: [id], onDelete: Cascade)
  sourcePurchase CreditPurchase @relation(fields: [sourcePurchaseId], references: [id], onDelete: Cascade)

  @@index([referrerTenantId, createdAt(sort: Desc)])
  @@index([refereeTenantId])
}
