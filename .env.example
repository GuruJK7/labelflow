# -- BASE DE DATOS --
DATABASE_URL=postgresql://postgres:password@localhost:5432/labelflow
DIRECT_URL=postgresql://postgres:password@localhost:5432/labelflow

# -- SUPABASE --
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=labels

# -- AUTH --
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-con-openssl-rand-base64-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# -- REDIS (UPSTASH) --
REDIS_URL=redis://localhost:6379

# -- STRIPE --
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PRO=price_xxx

# -- ENCRYPTION --
ENCRYPTION_KEY=genera-32-bytes-hex-con-openssl-rand-hex-32

# -- ADMIN ACCESS --
ADMIN_TENANT_IDS=                      # Comma-separated tenant IDs that can see all reports (e.g. id1,id2,id3)

# -- WORKER --
WORKER_CONCURRENCY=2
PLAYWRIGHT_HEADLESS=true
LABELS_TMP_DIR=/tmp/labelflow

# -- MCP --
MCP_SECRET=genera-con-openssl-rand-base64-32

# -- WHATSAPP (Recover Module) --
WHATSAPP_API_TOKEN=                    # Meta Cloud API permanent token
WHATSAPP_PHONE_NUMBER_ID=             # ID del numero en Meta Business
WHATSAPP_BUSINESS_ACCOUNT_ID=         # WABA ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=        # Token aleatorio para verificacion webhook Meta (openssl rand -hex 24)
WHATSAPP_APP_SECRET=                  # App Secret de Meta (para verificar firma HMAC en webhooks POST)
RECOVER_MERCADOPAGO_PLAN_ID=          # ID del plan de suscripcion en MercadoPago
MERCADOPAGO_WEBHOOK_SECRET=           # Webhook signing secret from MercadoPago (required — rejects all webhooks if unset)

# -- SHOPIFY --
# App shared secret from Shopify Partner Dashboard → Apps → [app] → App credentials.
# REQUIRED for webhook HMAC verification (C-1/C-2 fix). Same secret signs every
# webhook across every installed store — do NOT confuse with per-store Admin
# API access tokens stored in `tenant.shopifyToken`.
SHOPIFY_API_SECRET=

# -- APP --
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=LabelFlow

# -- CLAUDE ADDRESS-CORRECTION (YELLOW/RED flow) --
# Primary path: Tailscale bridge to the Mac Mini running Claude Max ($0/call).
# If unreachable, the worker transparently falls back to the Anthropic API.
LABELFLOW_BRIDGE_URL=http://100.x.x.x:7777    # Tailscale IP of the Mac Mini
LABELFLOW_BRIDGE_SECRET=                       # Shared secret — generated by install.sh (openssl rand -hex 32)
LABELFLOW_BRIDGE_TIMEOUT_MS=120000

# Fallback: direct Anthropic API with haiku (~$0.0008/call). Always set on Render.
ANTHROPIC_API_KEY=sk-ant-api03-xxx
LABELFLOW_API_TIMEOUT_MS=30000
