# LabelFlow bridge env — copy to bridge.env and chmod 600.
# Secret shared with the Render worker (X-Labelflow-Secret header).
# Generate with: openssl rand -hex 32
LABELFLOW_BRIDGE_SECRET=REPLACE_WITH_32_BYTE_HEX

# Port the bridge listens on. Tailscale ACLs / macOS firewall should restrict
# who can reach it. 7777 by default.
BRIDGE_PORT=7777

# Bind address. 0.0.0.0 lets Tailscale reach it; use 127.0.0.1 for
# local-only testing.
BRIDGE_HOST=0.0.0.0

# Path to the `claude` CLI binary. Default resolves from $HOME.
# CLAUDE_BIN=/Users/jk7/.local/bin/claude

# Claude spawn timeout in ms. 180s budget for Address Resolver Pro (Sonnet
# + WebSearch/WebFetch + Bash on hard cases). YELLOW corrections still finish
# in ~15-30 s because the prompt instructs Claude to skip tools when not needed.
CLAUDE_TIMEOUT_MS=180000

# Address Resolver Pro (Fase 1 + Fase 2, 2026-05-08) — overrides for the
# Claude CLI invocation. Defaults match the resolver-pro deployment.
# CLAUDE_MODEL=sonnet                        # 'haiku' (fast, basic) or 'sonnet' (richer reasoning)
# CLAUDE_TOOLS=Read,Write,WebSearch,WebFetch,Bash
# PYTHON_HELPERS_DIR=/Users/jk7/labelflow-tools  # dac_catalog.py + geocode.py
